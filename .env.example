# Copy to `.env` and fill in real values. Restart the dev server after changes.

NODE_ENV=development
APP_URL_NEXT=http://localhost:3000
AUTH_SECRET=change-this-to-a-long-random-secret

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=imperialtuitions
DB_USERNAME=root
DB_PASSWORD=root

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME=Imperial Tuitions
